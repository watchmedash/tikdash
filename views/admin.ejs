<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
</head>
<body>
    <div class="admin-container">
        <h1><i class="fas fa-cogs"></i> Game Admin Panel</h1>
        <div class="team-editor-container">
            <!-- Team 1 Editor -->
            <div class="team-editor">
                <form action="/admin/upload/team" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="teamId" value="team1">
                    <input type="text" name="teamName" placeholder="Team 1 Name" required>
                    <label class="file-label">
                        <i class="fas fa-image"></i> Image (Optional)
                        <input type="file" name="teamImage" accept="image/*">
                    </label>
                    <button type="submit"><i class="fas fa-save"></i> Save</button>
                </form>
            </div>
            <!-- Team 2 Editor -->
            <div class="team-editor">
                <form action="/admin/upload/team" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="teamId" value="team2">
                    <input type="text" name="teamName" placeholder="Team 2 Name" required>
                    <label class="file-label">
                        <i class="fas fa-image"></i> Image (Optional)
                        <input type="file" name="teamImage" accept="image/*">
                    </label>
                    <button type="submit"><i class="fas fa-save"></i> Save</button>
                </form>
            </div>
        </div>

        <div class="game-controls">
            <button id="start-game-btn"><i class="fas fa-play"></i> Start Game</button>
        </div>

        <!-- Add/Edit Gift Form -->
        <div class="form-container">
            <h2>Add Gift (with Image)</h2>
            <form action="/admin/upload/gift" method="POST" enctype="multipart/form-data">
                <input type="text" name="giftName" placeholder="Gift Name (Exact Match)" required>
                <input type="number" name="giftPoints" placeholder="Points" required>
                <select name="giftTeam" required>
                    <option value="1">Team 1</option>
                    <option value="2">Team 2</option>
                </select>
                <label class="file-label">
                    <i class="fas fa-image"></i> Gift PNG
                    <input type="file" name="giftImage" accept="image/png" required>
                </label>
                <button type="submit"><i class="fas fa-plus"></i> Add Gift</button>
            </form>
        </div>

        <!-- Gift List -->
        <div class="list-container">
            <h2>Configured Gifts</h2>
            <div id="gift-list"></div>
        </div>

        <!-- Add/Edit Comment Form -->
        <div class="form-container">
            <h2>Add Comment Keyword</h2>
            <form id="add-comment-form">
                <input type="text" id="comment-word" placeholder="Comment word (lowercase)" required>
                <input type="number" id="comment-points" placeholder="Points" required>
                <select id="comment-team">
                    <option value="1">Team 1</option>
                    <option value="2">Team 2</option>
                </select>
                <button type="submit"><i class="fas fa-plus"></i> Add Word</button>
            </form>
        </div>

        <!-- Comment List -->
        <div class="list-container">
            <h2>Configured Comments</h2>
            <div id="comment-list"></div>
        </div>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>
